#
# Polymarket Weather Bot - Phase 1 runtime configuration
#

# ====== Polymarket / CLOB ======
POLYMARKET_PRIVATE_KEY=your_private_key_here
FUNDER_ADDRESS=your_polygon_wallet_address_here
CHAIN_ID=137
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# ====== Notifications ======
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MENU_ENABLED=true

# ====== Paris Today Paper Bot ======
PARIS_BOT_DRY_RUN=true
PARIS_BOT_POLL_SECONDS=300
PARIS_BOT_PAPER_MIN_TRADE_USD=1
PARIS_BOT_PAPER_MAX_TRADE_USD=15
PARIS_BOT_PAPER_START_BALANCE_USD=1000
PARIS_BOT_PAPER_CLOSE_EDGE=0.00
PARIS_BOT_MIN_EDGE_TO_OPEN=0.10
PARIS_BOT_MIN_EDGE_TO_HOLD=0.03
PARIS_BOT_MIN_NO_PRICE=0.05
PARIS_BOT_MAX_YES_PRICE=0.95
PARIS_BOT_TELEGRAM_BOT_TOKEN=
PARIS_BOT_TELEGRAM_CHAT_ID=
PARIS_BOT_TELEGRAM_MENU_ENABLED=true

# ====== Weather providers ======
# Optional but recommended for better station-level observations.
SYNOPTIC_API_TOKEN=

# RainViewer metadata toggle for radar availability checks.
RAINVIEWER_ENABLED=true
DATA_RETENTION_DAYS=14
STARTUP_VALIDATION_ALERTS=true
SNAPSHOT_ARCHIVE_ENABLED=true
SNAPSHOT_ARCHIVE_DIR=data/snapshots
SNAPSHOT_ARCHIVE_MAX_LOOKUP_HOURS=72

# ====== Runtime mode ======
DRY_RUN=true
IS_PAUSED=false

# ====== Risk / sizing ======
MAX_TRADE_SIZE_USD=20
DEFAULT_TRADE_SIZE=15
MIN_TRADE_USD=1
MAX_TOTAL_EXPOSURE=0.20
MAX_CITY_EXPOSURE=0.10
MAX_SINGLE_TRADE_EXPOSURE=0.05

# ====== Scan cadence ======
SCAN_INTERVAL_HOURS=1
SCAN_DAYS_AHEAD=2
RESOLUTION_CHECK_INTERVAL_MINUTES=15

# ====== BMA analysis ======
ANALYSIS_MODEL=bma
BMA_MIN_CONFIDENCE=0.35
BMA_ENTRY_MIN_HOURS_TO_CLOSE=12
BMA_ENTRY_MAX_HOURS_TO_CLOSE=72
BMA_MIN_DAILY_VOLUME_USD=200
BMA_TARGET_DAILY_VOLUME_USD=2500
BMA_MAX_SPREAD=0.20
BMA_MAX_CITY_POSITIONS=3
BMA_LADDER_ENABLED=true
BMA_LADDER_MAX_PRICE=0.35
BMA_LADDER_MAX_POSITIONS=3
BMA_LADDER_PACKAGE_CAP=0.06
BMA_LADDER_MIN_PACKAGE_EV=0.10
BMA_LADDER_MIN_PRICE=0.02
BMA_MIN_EXECUTABLE_PRICE=0.02
BMA_MAX_EXECUTABLE_PRICE=0.98
BMA_MIN_EV_FOR_MIN_TRADE=0.18
BMA_PHASE2_MIN_EDGE_PCT=25
BMA_PHASE2_FAT_TAIL_MIN_EDGE_PCT=35
BMA_PHASE2_MIN_CONFIDENCE_PCT=70
BMA_PHASE2_MIN_LIQUIDITY_FACTOR=0.15
BMA_PHASE2_MAX_MARKET_SPREAD=0.20
BMA_PHASE2_MIN_ROI=0.35
BMA_PHASE2_FAT_TAIL_PRICE_CAP=0.15
BMA_FEE_BPS=0
BMA_MAX_ORDERBOOK_SLIPPAGE_PCT=8
BMA_MIN_SECONDS_BETWEEN_LIVE_ORDERS=5
BMA_REENTRY_COOLDOWN_MINUTES=180
BMA_HOLD_TAIL_MAX_ENTRY_PRICE=0.10
BMA_HOLD_TAIL_MIN_PROB=0.12
BMA_EXIT_PROB_DROP_POINTS=10
BMA_EXIT_EDGE_FLOOR=2
BMA_EXIT_CONFIDENCE_FLOOR=0.25
BMA_EXIT_CONFIDENCE_EDGE_FLOOR=4
BMA_EXIT_PROBABILITY_COLLAPSE_POINTS=35
BMA_EXIT_PROBABILITY_FLOOR=0.35
BMA_EXIT_MODEL_FLIP_FLOOR=0.30
BMA_ENTRY_MARKET_CONFLICT_DIVERGENCE=0.35
BMA_OPEN_METEO_CACHE_TTL_SECONDS=1800

# ====== Portfolio / calibration ======
KELLY_FRACTION=0.10
CALIBRATION_MIN_TRADES=3
